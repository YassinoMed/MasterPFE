@startuml
title SecureRAG Hub - Deployment Target Architecture

skinparam shadowing false
skinparam backgroundColor white
skinparam defaultFontName "IBM Plex Sans"
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam wrapWidth 220

skinparam ArrowColor #315E9C
skinparam ArrowThickness 1.2

skinparam rectangle {
  BackgroundColor #F8FBFF
  BorderColor #7C93B8
  RoundCorner 16
}

skinparam node {
  BackgroundColor #F4F7FB
  BorderColor #7C93B8
  RoundCorner 18
}

skinparam database {
  BackgroundColor #F7FAFD
  BorderColor #7C93B8
}

skinparam artifact {
  BackgroundColor #F9FBFE
  BorderColor #95A8C8
}

legend right
|= Zone |= Role |
| GitHub / DevSecOps | Build, scan, SBOM, signature, publication |
| Machine locale / VM | Portail web Laravel, scripts de deploiement |
| Cluster kind | Runtime applicatif SecureRAG Hub |
endlegend

actor "Utilisateur metier" as user
actor "Administrateur" as admin

cloud "GitHub / Depot source" as github {
  folder "Monorepo SecureRAG Hub\n- services/\n- infra/\n- platform/\n- Jenkinsfile\n- Jenkinsfile.cd\n- docs/\n- scripts/" as repo

  package "Chaine DevSecOps" as ci {
    node "Jenkins CI\nlint / tests / scans" as gha
    node "Jenkins CD\nbuild / SBOM / sign / deploy" as jcd
    artifact "Rapports securite\nSemgrep / Gitleaks / Trivy" as reports
    artifact "SBOM CycloneDX\nSyft" as sbom
    artifact "Signature OCI\nCosign" as cosign
  }

  database "Registry OCI\nGHCR ou localhost:5001" as registry
}

node "Machine locale / VM de demonstration" as vm {
  node "Portail Web Laravel\nportal-web + gateway" as portal

  artifact "Kustomize overlays/dev\nManifests a valider" as manifests
  artifact "Scripts locaux\nkind / deploy / validate" as scripts

  node "Cluster Kubernetes local (kind)" as kind {
    frame "Namespace securerag-hub" as ns {
      node "Entree HTTP locale\nNodePort portal-web" as edge
      node "Service portal-web" as portal_svc

      frame "Pods applicatifs" as pods {
        node "Pod portal-web" as portal_pod
        node "Pod auth-users" as auth_pod
        node "Pod chatbot-manager" as chatbot_pod
        node "Pod conversation-service" as conversation_pod
        node "Pod audit-security-service" as audit_pod
      }

      frame "Controles Kubernetes" as k8s_controls {
        artifact "ServiceAccounts\ndedies par microservice" as sa
        artifact "NetworkPolicies" as np
        artifact "Secrets" as secrets
        artifact "ConfigMaps" as cm
      }
    }
  }
}

repo --> gha : push / pull request
repo --> jcd : release / promotion
repo --> manifests : versionne\nbase + overlays/dev
repo --> scripts : execution locale

gha --> reports : scans SAST / secrets / images
jcd --> sbom : generation inventaire
jcd --> cosign : signature des artefacts
jcd --> registry : publication images signees

scripts --> kind : create-kind / deploy-kind
manifests --> kind : deploiement via Kustomize
registry --> kind : pull images

user --> portal : interface web
admin --> portal : administration / supervision
portal --> edge : HTTP local demo
edge --> portal_svc : routage d'entree
portal_svc --> portal_pod : trafic web

portal_pod --> auth_pod : authentification / RBAC
portal_pod --> chatbot_pod : catalogue / configuration
portal_pod --> conversation_pod : historique / conversations
portal_pod --> audit_pod : audit / evenements securite

chatbot_pod --> cm : lecture configuration
auth_pod --> secrets : lecture secrets / tokens
conversation_pod --> secrets : lecture secrets / tokens
audit_pod --> secrets : lecture secrets / tokens

sa ..> portal_pod
sa ..> auth_pod
sa ..> chatbot_pod
sa ..> conversation_pod
sa ..> audit_pod

np ..> portal_pod
np ..> auth_pod
np ..> chatbot_pod
np ..> conversation_pod
np ..> audit_pod

cm ..> chatbot_pod
cm ..> conversation_pod
cm ..> audit_pod
secrets ..> conversation_pod
secrets ..> audit_pod

note bottom of portal
Portail Web Laravel integre au runtime kind
officiel. Les anciens composants Python/RAG
sont hors perimetre de deploiement tant que
leurs sources applicatives sont absentes.
end note

note bottom of gha
Le pipeline CI reste focalise sur la qualite
et les controles de securite continus.
end note

note bottom of jcd
Le CD vers kind repose sur un agent Jenkins self-hosted
ou sur des scripts locaux, afin de rester 100% local.
end note

@enduml
